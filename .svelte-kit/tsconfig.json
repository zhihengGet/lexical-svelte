{
	"compilerOptions": {
		"paths": {
			"@nodes/*": [
				"../src/playground/nodes/*"
			],
			"@plugins/*": [
				"../src/playground/plugins/*"
			],
			"shared/*": [
				"../src/utils/*"
			],
			"@shared/*": [
				"../src/shared/*"
			],
			"@lexical/react/*": [
				"../src/lib/*"
			],
			"@theme/*": [
				"../src/themes/*"
			],
			"@ui/*": [
				"../src/playground/ui/*"
			],
			"react": [
				"../src/react.svelte.js"
			],
			"$lib": [
				"../src/lib"
			],
			"$lib/*": [
				"../src/lib/*"
			]
		},
		"rootDirs": [
			"..",
			"./types"
		],
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"lib": [
			"esnext",
			"DOM",
			"DOM.Iterable"
		],
		"moduleResolution": "bundler",
		"module": "esnext",
		"noEmit": true,
		"target": "esnext",
		"baseUrl": "."
	},
	"include": [
		"ambient.d.ts",
		"non-ambient.d.ts",
		"./types/**/$types.d.ts",
		"../vite.config.js",
		"../vite.config.ts",
		"../src/**/*.js",
		"../src/**/*.ts",
		"../src/**/*.svelte",
		"../tests/**/*.js",
		"../tests/**/*.ts",
		"../tests/**/*.svelte",
		"**/*.test.ts"
	]
}